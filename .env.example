# 默认使用 FunASR 服务，不需要本机 Whisper 模型。
ASR_ENGINE=funasr
# 指向本地 Paraformer-large 服务（精度优于 SenseVoiceSmall）
FUNASR_ENDPOINT=http://127.0.0.1:10095
FUNASR_MODEL=iic/speech_seaco_paraformer_large_asr_nat-zh-cn-16k-common-vocab8404-pytorch
FUNASR_VAD_MODEL=iic/speech_fsmn_vad_zh-cn-16k-common-pytorch
FUNASR_PUNC_MODEL=iic/punc_ct-transformer_zh-cn-common-vocab272727-pytorch
FUNASR_DEVICE=cpu
# 需要更低延迟时设置 FUNASR_QUANTIZE=1（INT8 推理，CPU 上提速明显）
FUNASR_QUANTIZE=0

# 远程/旧 SenseVoice 服务（如果暂时不想切本地）
# FUNASR_ENDPOINT=http://10.254.81.32:10095
# FUNASR_MODEL=iic/SenseVoiceSmall

# 可选：如果用户自行部署本地 whisper.cpp，再配置以下路径。
# WHISPER_CLI_PATH=/opt/homebrew/bin/whisper-cli
# WHISPER_MODEL_PATH=/Users/black/models/whisper/ggml-large-v3.bin
# WHISPER_THREADS=8

# DeepSeek key 不要写进前端代码；复制为 .env.local 后填写。
DEEPSEEK_API_KEY=REPLACE_WITH_YOUR_DEEPSEEK_KEY

# DeepSeek 官方 OpenAI-compatible chat endpoint 默认可用 deepseek-chat。
# 如果你的账号/供应商已有明确 flash 模型 ID，在这里覆盖即可。
DEEPSEEK_MODEL=deepseek-v4-flash

# =============================================================================
# 切换到其它 LLM 服务（推荐 GLM-4-Flash，速度快、中文好）
# 取消下面一行的注释并填入对应 key，桌面端会自动用这个 base URL 调 /chat/completions。
# 留空时：使用上面 DeepSeek 官方（仅当 DEEPSEEK_API_KEY 有效时生效）。
# =============================================================================
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_BASE_URL=http://127.0.0.1:11434/v1     # Ollama 本地
# DEEPSEEK_MODEL=glm-4-flash                  # GLM
# DEEPSEEK_MODEL=qwen-turbo                   # 通义千问
# DEEPSEEK_MODEL=qwen2.5:3b                   # Ollama 本地

# 是否启用 AI 润色：0/false/no/off 关闭（直接输出识别原文），1/true 开启（默认）。
# 也可以在 UI 的"AI 设置 → AI 润色"开关里切换并保存。
POLISH_ENABLED=1
