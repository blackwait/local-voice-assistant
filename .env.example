# 默认使用 FunASR 服务，不需要本机 Whisper 模型。
ASR_ENGINE=funasr
FUNASR_ENDPOINT=http://10.254.81.32:10095
FUNASR_MODEL=iic/SenseVoiceSmall
FUNASR_DEVICE=cpu

# 可选：如果用户自行部署本地 whisper.cpp，再配置以下路径。
# WHISPER_CLI_PATH=/opt/homebrew/bin/whisper-cli
# WHISPER_MODEL_PATH=/Users/black/models/whisper/ggml-large-v3.bin
# WHISPER_THREADS=8

# DeepSeek key 不要写进前端代码；复制为 .env.local 后填写。
DEEPSEEK_API_KEY=REPLACE_WITH_YOUR_DEEPSEEK_KEY

# DeepSeek 官方 OpenAI-compatible chat endpoint 默认可用 deepseek-chat。
# 如果你的账号/供应商已有明确 flash 模型 ID，在这里覆盖即可。
DEEPSEEK_MODEL=deepseek-v4-flash
